{
  "info": {
    "name": "IGBC AI Certification Platform - Integration Workflow",
    "_postman_id": "fe4a3a2e-2b7f-44a7-9d13-igbc00000001",
    "description": "End-to-end integration tests for authentication, projects, documents, AI validation, assessments, reports, certificates, and dashboard stats.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "adminToken", "value": "" },
    { "key": "assessorToken", "value": "" },
    { "key": "companyToken", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "documentId", "value": "" },
    { "key": "assessmentId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "certificateId", "value": "" },
    { "key": "certificateNumber", "value": "" },
    { "key": "assessorId", "value": "665000000000000000000002" }
  ],
  "item": [
    {
      "name": "01 Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "02 Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin.tester@igbc.local\",\n  \"password\": \"Admin123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "03 Login Assessor",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('assessorToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"assessor.tester@igbc.local\",\n  \"password\": \"Assessor123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "04 Register Company User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('companyToken', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"IGBC Test Company User API\",\n  \"email\": \"company.api.tester@igbc.local\",\n  \"password\": \"Company123!\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "05 Create Project",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('projectId', json.data.project._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{companyToken}}", "type": "string" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectName\": \"IGBC Integration Test Tower\",\n  \"companyName\": \"IGBC Demo Developers Pvt Ltd\",\n  \"projectType\": \"Commercial Office\",\n  \"location\": \"Bengaluru, Karnataka\",\n  \"description\": \"Integration test project for validating the complete IGBC certification workflow.\",\n  \"status\": \"Draft\",\n  \"assessmentStage\": \"Preliminary\"\n}"
        },
        "url": "{{baseUrl}}/api/projects"
      }
    },
    {
      "name": "06 Upload Document",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('documentId', json.data.document._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{companyToken}}", "type": "string" }] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "projectId", "value": "{{projectId}}", "type": "text" },
            { "key": "category", "value": "Energy", "type": "text" },
            { "key": "file", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/api/documents/upload"
      }
    },
    {
      "name": "07 Create Assessment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('assessmentId', json.data.assessment._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"assessorId\": \"{{assessorId}}\",\n  \"assessmentType\": \"Preliminary\",\n  \"status\": \"Pending\",\n  \"score\": 72,\n  \"maxScore\": 100,\n  \"rating\": \"Silver\",\n  \"creditsEarned\": 36,\n  \"assessorComments\": \"Initial submission is complete enough for preliminary review.\",\n  \"aiScore\": 0,\n  \"aiRecommendation\": \"\"\n}"
        },
        "url": "{{baseUrl}}/api/assessments"
      }
    },
    {
      "name": "08 Analyze Uploaded Document",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{assessorToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/ai/analyze/{{documentId}}"
      }
    },
    {
      "name": "09 Generate Project AI Score",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{assessorToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/ai/score/{{projectId}}"
      }
    },
    {
      "name": "10 Get AI Recommendations",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{assessorToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/ai/recommendations/{{projectId}}"
      }
    },
    {
      "name": "11 Submit Assessment",
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{assessorToken}}", "type": "string" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 82,\n  \"maxScore\": 100,\n  \"rating\": \"Gold\",\n  \"creditsEarned\": 41,\n  \"assessorComments\": \"Assessment submitted with Gold rating recommendation.\",\n  \"aiScore\": 80,\n  \"aiRecommendation\": \"Proceed with final certification review.\"\n}"
        },
        "url": "{{baseUrl}}/api/assessments/{{assessmentId}}/submit"
      }
    },
    {
      "name": "12 Generate Report",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('reportId', json.data.report._id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{assessorToken}}", "type": "string" }] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reportType\": \"Preliminary\",\n  \"assessmentId\": \"{{assessmentId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/reports/generate/{{projectId}}"
      }
    },
    {
      "name": "13 Generate Certificate",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('certificateId', json.data.certificate._id);",
              "pm.collectionVariables.set('certificateNumber', json.data.certificate.certificateNumber);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/certificates/generate/{{projectId}}"
      }
    },
    {
      "name": "14 Verify Certificate",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/certificates/verify/{{certificateNumber}}"
      }
    },
    {
      "name": "15 Dashboard Stats",
      "request": {
        "method": "GET",
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
        "url": "{{baseUrl}}/api/dashboard/stats"
      }
    }
  ]
}
